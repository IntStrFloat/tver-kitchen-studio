# ─────────────────────────────────────────────────────────────
# Отправка заявок с сайта на почту (Brevo HTTP API)
# ─────────────────────────────────────────────────────────────
# Хостер блокирует исходящий SMTP (порты 25/465/587), поэтому письма
# уходят через HTTP-API сервиса Brevo (https://www.brevo.com) по порту 443.
#
# Скопируйте этот файл в `.env.local` (локально) или задайте те же
# переменные в /etc/tver-kitchen-studio.env на проде, затем
# `systemctl restart tver-kitchen-studio`.
#
# Без этих переменных форма заявок вернёт 503 (Mail not configured).

# API-ключ Brevo: Brevo → SMTP & API → API Keys → Generate a new API key.
# Начинается с "xkeysib-".
BREVO_API_KEY=

# Адрес отправителя. Должен быть ПОДТВЕРЖДЁН в Brevo
# (Senders, Domains & Dedicated IPs → Senders), иначе письма не уйдут.
MAIL_FROM=kuhnitver-zayavki@yandex.com

# Имя отправителя (необязательно). По умолчанию: «Кухни Тверь — заявки с сайта».
# MAIL_FROM_NAME=Кухни Тверь — заявки с сайта

# Куда присылать заявки. Можно несколько адресов через запятую.
MAIL_TO=Gostlix10@yandex.ru
