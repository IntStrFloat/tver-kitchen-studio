# ─────────────────────────────────────────────────────────────
# Отправка заявок с сайта на почту (SMTP)
# ─────────────────────────────────────────────────────────────
# Скопируйте этот файл в `.env.local` (локально) или задайте те же
# переменные в /etc/tver-kitchen-studio.env на проде, затем
# `systemctl restart tver-kitchen-studio`.
#
# Без этих переменных форма заявок вернёт 503 (Mail not configured).

# SMTP-сервер вашего почтового провайдера.
#   Яндекс 360 :  smtp.yandex.ru   порт 465
#   Mail.ru    :  smtp.mail.ru     порт 465
#   Gmail      :  smtp.gmail.com   порт 465
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465

# Опционально. По умолчанию: true для порта 465 (TLS),
# false для 587 (STARTTLS). Обычно менять не нужно.
# SMTP_SECURE=true

# Логин и пароль для SMTP. Для Яндекс/Mail.ru/Gmail используйте
# «пароль приложения», а не основной пароль от аккаунта.
SMTP_USER=zayavki@kuhnitver.ru
SMTP_PASS=

# Куда присылать заявки. Можно несколько адресов через запятую.
MAIL_TO=owner@kuhnitver.ru

# Опционально. Адрес отправителя. По умолчанию = SMTP_USER.
# Многие провайдеры требуют, чтобы From совпадал с SMTP_USER.
# MAIL_FROM=zayavki@kuhnitver.ru
